# Database
DATABASE_URL="mysql://usuario:password@localhost:3306/portfolio_db"

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=tu_secreto_jwt_super_seguro_cambialo_en_produccion
JWT_REFRESH_SECRET=tu_secreto_refresh_jwt_super_seguro_cambialo_en_produccion
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Admin Credentials (para seed inicial)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin123!

# Email Configuration (opcional - para formulario de contacto)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion
EMAIL_FROM=noreply@portfolio.com

# CORS
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads
